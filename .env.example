# LLM Configuration
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Database
POSTGRES_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Application
NEXUS_ENV=development
LOG_LEVEL=INFO
STEP_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# Observability
PROMETHEUS_PORT=9090
