# ── LLM ───────────────────────────────────────────────────────────────────────
# OpenAI-compatible key. Leave blank to use keyword fallbacks (no LLM calls).
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1   # override for local Ollama/vLLM

# ── Environment ───────────────────────────────────────────────────────────────
NEXUS_ENV=development          # development | production | test
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus
POSTGRES_PASSWORD=nexus        # used by docker-compose postgres service

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Execution ─────────────────────────────────────────────────────────────────
STEP_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Grafana (docker-compose only) ─────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=nexus
